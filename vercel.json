{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://<SERVER_URL>/api/$1"
    },
    {
      "source": "/v1/(.*)",
      "destination": "https://<SERVER_URL>/v1/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
